# Redwood AI Insurance Platform — shared environment configuration
# Copy to .env and fill in values before running docker compose or any sub-project.
# Never commit .env to source control.
#
# Sub-project usage legend:
#   [data]          insurance-data-platform
#   [uw]            intelligent-underwriting-platform
#   [fraud]         ai-fraud-detection-platform
#   [fnol]          fnol-claims-multi-agent-system
#   [rag]           enterprise-rag-platform

# ── LLM ───────────────────────────────────────────────────────────────────────
# [uw] [fnol]
ANTHROPIC_API_KEY=sk-ant-...

# ── Redis (online feature store) ──────────────────────────────────────────────
# [data] [uw] [fraud] [fnol]
REDIS_URL=redis://localhost:6379

# ── Neo4j (graph intelligence) ────────────────────────────────────────────────
# [data] [uw] [fraud] [fnol]
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# ── Data platform root ────────────────────────────────────────────────────────
# [uw] [fraud] — path to insurance-data-platform repo; defaults to ../insurance-data-platform
# DATA_PLATFORM_ROOT=/absolute/path/to/insurance-data-platform

# ── RAG platform ──────────────────────────────────────────────────────────────
# [rag]
# Local dev: local-st + faiss (no AWS required)
# Production: bedrock-titan + opensearch
EMBEDDER_BACKEND=local-st
VECTOR_STORE_BACKEND=faiss
EMBEDDING_CACHE_BACKEND=in-memory
INGEST_DOCS_ROOT=/data/rag/documents
FAISS_INDEX_PATH=/tmp/rag/faiss.index
BM25_INDEX_PATH=/tmp/rag/bm25.index
RERANKER_BACKEND=local-ce

# Required only when VECTOR_STORE_BACKEND=opensearch:
# OPENSEARCH_ENDPOINT=your-collection-id.us-east-1.aoss.amazonaws.com
# OPENSEARCH_INDEX=rag-chunks

# Required only when EMBEDDING_CACHE_BACKEND=redis:
# (REDIS_URL above is reused)

# Required only when RERANKER_BACKEND=cohere:
# COHERE_API_KEY=your-cohere-api-key
# COHERE_RERANK_MODEL_ID=rerank-english-v3.0

# ── AWS (required for bedrock-titan, opensearch, or dynamodb backends) ────────
# [rag] [uw]
BEDROCK_REGION=us-east-1

# ── FNOL inter-service URLs ───────────────────────────────────────────────────
# [fnol] — override when running services outside Docker (docker compose sets these automatically)
# FRAUD_SCORING_URL=http://localhost:8002
# RAG_URL=http://localhost:8003

# ── FNOL storage ──────────────────────────────────────────────────────────────
# [fnol]
S3_LABEL_BUCKET=fnol-labels
ENV=dev

# ── Docker host user (prevents root-owned files on Linux) ─────────────────────
# [data] — run: echo "HOST_UID=$(id -u)" >> .env && echo "HOST_GID=$(id -g)" >> .env
HOST_UID=1000
HOST_GID=1000
